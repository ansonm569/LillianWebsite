# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret — create an endpoint for
# https://<your-domain>/api/stripe-webhook listening to payment_intent.succeeded
# at https://dashboard.stripe.com/webhooks (or `stripe listen` locally)
STRIPE_WEBHOOK_SECRET=whsec_...

# Sales tax is calculated with Stripe Tax (no extra env var needed). Activate
# it at https://dashboard.stripe.com/settings/tax: set the origin address and
# add registrations for states where you collect (e.g. Wisconsin). If Stripe
# Tax is not activated, checkout still works and charges no tax.

# Resend — https://resend.com/api-keys (used for the commission contact form
# and sale notification emails)
RESEND_API_KEY=re_...

# Sender address for outgoing email. Leave unset to use Resend's sandbox
# sender (only delivers to the Resend account owner). After verifying the
# domain at https://resend.com/domains, set e.g.:
# EMAIL_FROM=no-reply@lillianmackinney.com
